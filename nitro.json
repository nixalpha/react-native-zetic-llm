{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "zeticllm"
  ],
  "ios": {
    "iosModuleName": "NitroZeticLlm"
  },
  "android": {
    "androidNamespace": [
      "zeticllm"
    ],
    "androidCxxLibName": "NitroZeticLlm"
  },
  "autolinking": {
    "ZeticLLM": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridZeticLLM"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridZeticLLM"
      }
    },
    "ZeticAgent": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridZeticAgent"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridZeticAgent"
      }
    },
    "ZeticAgentShadowTree": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridZeticAgentShadowTree"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
